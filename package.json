{
  "name": "docs-folio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "tsx watch server.ts",
    "dev:full": "concurrently \"npm run dev:api\" \"npm run dev\"",
    "content:create-cms": "tsx scripts/create-canvas-cms.ts",
    "content:sync": "tsx scripts/sync-content.ts",
    "content:publish": "npm run build && git status --short",
    "build": "npm run content:sync && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^1.30.0",
    "@notionhq/client": "^4.0.2",
    "@vercel/analytics": "^1.5.0",
    "dotenv": "^17.2.3",
    "lucide-react": "^0.554.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@vercel/node": "^5.5.8",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.7.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
